{
  "name": "@alesya_h/jsmcp",
  "version": "1.0.1",
  "description": "MCP server that allows agents to work with other MCP tools programmatically by writing JavaScript",
  "license": "MIT",
  "author": "Alesya Huzik",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "jsmcp": "src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
